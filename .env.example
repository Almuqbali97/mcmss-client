# API base URL (backend). Must include /api, or the host only (e.g. https://your-api.onrender.com).
# Vite bakes this in at build time — change it, then rebuild/redeploy the frontend.
VITE_API_URL=http://localhost:3001/api

# Production example:
# VITE_API_URL=https://mcmss-research-platform-server.onrender.com/api
